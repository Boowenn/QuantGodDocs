{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuantGod repository manifest",
  "type": "object",
  "required": [
    "repo",
    "role",
    "apiContractVersion"
  ],
  "properties": {
    "repo": {
      "type": "string"
    },
    "role": {
      "enum": [
        "backend",
        "frontend",
        "infra",
        "docs"
      ]
    },
    "apiContractVersion": {
      "type": "integer",
      "minimum": 1
    },
    "sourceOfTruth": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbiddenContents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "linkedRepos": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
